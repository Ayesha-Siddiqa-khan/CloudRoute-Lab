upstream cloudroute_gateway {
    # Replace these with the private IPs of Kubernetes worker nodes from:
    # terraform output kubernetes_worker_instances
    server REPLACE_WITH_WORKER_PRIVATE_IP:30080;
}

server {
    listen 80;
    server_name _;

    access_log /var/log/nginx/cloudroute-lab-access.log;
    error_log /var/log/nginx/cloudroute-lab-error.log;

    location / {
        proxy_pass http://cloudroute_gateway;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
